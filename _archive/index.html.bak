</section>



<!-- ══ FEATURED PRODUCT ═══════════════════════════════════════════════════════ -->
<section class="lm-featured-sec">
    <shopify-context type="product" handle="saree-15">
        <template>
        <div class="lm-featured-wrapper">

            <!-- Left: Content -->
            <div>
                <div class="lm-featured-tag">Timeless Beauty • Adrini Sarees</div>

                <h2 class="lm-featured-name">Grace In<br>Every Drape</h2>

                <p class="lm-featured-desc">
                    <shopify-data query="product.description"></shopify-data>
                </p>

                <button class="lm-featured-atc"
                    shopify-attr--data-id="product.selectedOrFirstAvailableVariant.id"
                    shopify-attr--data-title="product.title"
                    shopify-attr--data-price="product.priceRange.minVariantPrice.amount"
                    shopify-attr--data-img="product.featuredImage.url"
                    shopify-attr--data-handle="product.handle"
                    onclick="event.preventDefault(); window.addTemplateToCart(this)">
                    Shop Collection →
                </button>

                <div class="lm-featured-cards">
                    <div class="lm-featured-card">
                        <span>✦</span>
                        <p>Premium Fabrics</p>
                    </div>
                    <div class="lm-featured-card">
                        <span>❖</span>
                        <p>Artisan Crafted</p>
                    </div>
                    <div class="lm-featured-card">
                        <span>♡</span>
                        <p>Exclusive Designs</p>
                    </div>
                    <div class="lm-featured-card">
                        <span>➜</span>
                        <p>Fast Delivery</p>
                    </div>
                </div>
            </div>

            <!-- Right: Product Image -->
            <div class="lm-featured-img-side">
                <div class="lm-featured-img-wrap">
                    <shopify-media query="product.featuredImage" layout="fullWidth" aspect-ratio="0.75"></shopify-media>
                </div>
            </div>

        </div>
        </template>
    </shopify-context>
</section>
<!-- Shopify Cart Component -->
<shopify-cart id="main-cart"></shopify-cart>
</shopify-store>



<!-- ══ TRUST SIGNALS ══════════════════════════════════════════════════════════ -->
<section class="lm-trust-sec">
    <div class="lm-trust-header">
        <div class="lm-trust-eyebrow">Why Adrini</div>
        <h2 class="lm-trust-title">Every reason to trust us</h2>
    </div>
    <div class="lm-trust-grid" style="grid-template-columns:repeat(3,1fr)">
        <div class="lm-trust-card reveal">
            <span class="lm-trust-icon">↩️</span>
            <div class="lm-trust-card-title">7-day hassle-free returns</div>
            <div class="lm-trust-card-body">Not happy? Return it. No questions asked. Full refund to your account within 3 days.</div>
            <span class="lm-trust-impact">+25% more buyers</span>
        </div>
        <div class="lm-trust-card reveal">
            <span class="lm-trust-icon">📲</span>
            <div class="lm-trust-card-title">WhatsApp support</div>
            <div class="lm-trust-card-body">Real person. Real answers. We reply within 1 hour, Monday–Saturday, 9am–8pm.</div>
            <span class="lm-trust-impact">+30% conversion</span>
        </div>
        <div class="lm-trust-card reveal">
            <span class="lm-trust-icon">📦</span>
            <div class="lm-trust-card-title">COD available</div>
            <div class="lm-trust-card-body">Pay when it arrives at your door. No risk, no upfront payment required.</div>
            <span class="lm-trust-impact">+35% new buyers</span>
        </div>
    </div>
</section>


<!-- ══ WHATSAPP CTA ════════════════════════════════════════════════════════════ -->
<section id="contact" class="lm-wa-sec">
    <div class="lm-wa-left">
        <h2 class="lm-wa-title">Have a question? Chat with us.</h2>
        <p class="lm-wa-sub">We reply in minutes. Monday–Saturday, 9am–8pm IST.<br>Order on WhatsApp in 60 seconds — no website needed.</p>
    </div>
    <a href="https://wa.me/919999999999" target="_blank" class="lm-wa-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Chat on WhatsApp
    </a>
</section>

<!-- ══ EMAIL CAPTURE ══════════════════════════════════════════════════════════ -->
<section class="lm-email-sec">
    <div class="lm-email-eyebrow">Join 2,000+ women</div>
    <h2 class="lm-email-title">Get ₹200 off your first order</h2>
    <p class="lm-email-sub">New arrivals, exclusive offers, and saree care tips — straight to your inbox.</p>
    <form class="lm-email-form" onsubmit="return false">
        <input class="lm-email-input" placeholder="Your email address" type="email">
        <button class="lm-email-submit" type="submit">Claim ₹200</button>
    </form>
</section>

<!-- ══ FOOTER ═════════════════════════════════════════════════════════════════ -->
<footer class="lm-footer">
    <div class="lm-footer-top">
        <div class="lm-footer-brand">
            <div class="lm-footer-logo">L<span>OO</span>MYN</div>
            <p class="lm-footer-tagline">Handpicked sarees from India's finest weaving traditions. Delivered across India.</p>
            <div class="lm-footer-social">
                <div class="lm-footer-social-btn">In</div>
                <div class="lm-footer-social-btn">Ig</div>
                <div class="lm-footer-social-btn">Wa</div>
            </div>
        </div>
        <div>
            <div class="lm-footer-col-title">Shop</div>
            <div class="lm-footer-links">
                <a href="#" class="lm-footer-link" onclick="event.preventDefault(); sessionStorage.setItem('lm-collection-handle','kalyani-cotton'); window.location.href='collection.html'">Kalyani Cotton</a>
                <a href="#" class="lm-footer-link" onclick="event.preventDefault(); sessionStorage.setItem('lm-collection-handle','mul-cotton'); window.location.href='collection.html'">Mul Cotton</a>
                <a href="#" class="lm-footer-link" onclick="event.preventDefault(); sessionStorage.setItem('lm-collection-handle','kadhi-cotton'); window.location.href='collection.html'">Khadi Cotton</a>
                <a href="#" class="lm-footer-link" onclick="event.preventDefault(); sessionStorage.setItem('lm-collection-handle','banarasi'); window.location.href='collection.html'">Banarasi</a>
            </div>
        </div>
        <div>
            <div class="lm-footer-col-title">Help</div>
            <div class="lm-footer-links">
                <a href="#" class="lm-footer-link">About Adrini</a>
                <a href="#" class="lm-footer-link">Shipping policy</a>
                <a href="#" class="lm-footer-link">Returns</a>
                <a href="#" class="lm-footer-link">Contact us</a>
                <a href="#" class="lm-footer-link">Privacy policy</a>
            </div>
        </div>
    </div>
    <div class="lm-footer-bottom">
        <div class="lm-footer-copy">© 2026 Adrini Sarees. Kollam, Kerala, India. Made with love 🪡</div>
        <div class="lm-footer-gst">GST: 32XXXXX0000X1ZX</div>
    </div>
</footer>

<!-- ══ CART DRAWER ════════════════════════════════════════════════════════════ -->
<div id="cart-drawer" class="drawer">
    <div class="drawer-overlay"></div>
    <div class="drawer-content">
        <div class="drawer-header">
            <h3>Shopping Bag</h3>
            <button class="close-drawer">&times;</button>
        </div>
        <div id="cart-items" class="cart-items">
            <p class="empty-cart-msg">Your bag is empty.</p>
        </div>
        <div id="cart-recommendations" style="display:none; padding:16px 20px; border-top:0.5px solid rgba(26,18,8,0.08); background:#fcfaf5;">
            <div style="font-size:12px; font-weight:600; color:#1a1208; margin-bottom:12px; text-transform:uppercase; letter-spacing:0.04em;">Recommended for you</div>
            <div id="cart-rec-items" style="display:flex; flex-direction:column; gap:12px;"></div>
        </div>
        <div class="drawer-footer">
            <div class="cart-coupon" style="margin-bottom: 14px; padding-bottom: 14px; border-bottom: 0.5px solid rgba(26,18,8,0.08);">
                <div style="display:flex; gap:8px;">
                    <input type="text" id="coupon-code" placeholder="Discount code" style="flex:1; padding:8px 10px; border:1px solid rgba(26,18,8,0.15); border-radius:6px; font-size:12px; outline:none; text-transform:uppercase; background:#f8f4ec;">
                    <button onclick="window.applyCoupon && window.applyCoupon()" style="padding:0 14px; background:#1a1208; color:#fff; border:none; border-radius:6px; cursor:pointer; font-size:12px; font-weight:500;">Apply</button>
                </div>
                <div id="coupon-msg" style="font-size:11px; margin-top:6px; color:#085041; display:none;"></div>
            </div>
            <div class="cart-total">
                <span>Total</span>
                <span id="cart-total-amount">₹0</span>
            </div>
            <button class="lm-checkout-btn">Checkout</button>
        </div>
    </div>
</div>

<!-- ══ WISHLIST DRAWER ═══════════════════════════════════════════════════════ -->
<div id="wishlist-drawer" class="drawer">
    <div class="drawer-overlay" onclick="toggleWishlistDrawer()"></div>
    <div class="drawer-content">
        <div class="drawer-header">
            <h3>Your Wishlist</h3>
            <button class="close-drawer" onclick="toggleWishlistDrawer()">&times;</button>
        </div>
        <div id="wishlist-items" class="cart-items">
            <p class="empty-cart-msg">Your wishlist is empty.</p>
        </div>
        <div class="drawer-footer" style="display:none;" id="wishlist-footer">
            <button class="lm-checkout-btn" onclick="addAllWishlistToCart()" style="background:#c9943a; color:#1a1208; border:none; border-radius:4px; padding:12px; width:100%; cursor:pointer; font-weight:600; font-size:12px; letter-spacing:0.05em; text-transform:uppercase;">Add all to cart</button>
        </div>
    </div>
</div>




<!-- ══ QUICK VIEW MODAL ═══════════════════════════════════════════════════════ -->
<div id="quick-view" class="modal">
    <div class="modal-overlay"></div>
    <div class="modal-content">
        <button class="close-modal">&times;</button>
        <div class="qv-grid">
            <div class="qv-image"><img id="qv-img" src="" alt=""></div>
            <div class="qv-details">
                <span class="qv-brand">ADRINI</span>
                <h2 id="qv-title"></h2>
                <p id="qv-price" class="price"></p>
                <div class="qv-description"><p id="qv-desc"></p></div>
                <div class="qv-actions">
                    <button id="qv-atc" class="lm-hbtn-p" style="width:100%;justify-content:center">Add to Bag</button>
                </div>
            </div>
        </div>
    </div>
</div>



    <script src="src/scripts/main.js?v=20"></script>
</body>
</html>
