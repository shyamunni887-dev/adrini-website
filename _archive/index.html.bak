<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Adrini | Handwoven Sarees from Kerala</title>
    <meta name="description" content="Adrini — Handwoven sarees from Kerala's finest looms. Kasavu, Silk, Cotton, Bridal and Printed collections. Free shipping on all prepaid orders. 7-day returns.">
    <meta property="og:title" content="Adrini | Handwoven Sarees from Kerala">
    <meta property="og:description" content="Six yards of ancient craft. Every Adrini saree begins on a handloom in Kollam, Kerala.">
    <meta property="og:type" content="website">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="src/styles/index.css?v=47">
    
    <!-- Shopify Storefront Web Components -->
    <script type="module" src="https://cdn.shopify.com/storefront/web-components.js"></script>
</head>
<body>

<!-- ══ LOADER ═══════════════════════════════════════════════════════════════ -->
<div id="loader" class="loader-overlay">
    <div class="loader-content">
        <span class="loader-brand">ADRINI</span>
        <div class="loader-bar"></div>
    </div>
</div>

<!-- ══ NAV ══════════════════════════════════════════════════════════════════ -->

<header id="main-header" class="lm-nav fade-down">
    <a href="index.html" class="lm-nav-logo" style="text-decoration:none">ADRINI</a>
    <nav class="lm-nav-links">
        <a href="#" class="lm-nav-link" onclick="event.preventDefault(); (sessionStorage.setItem('lm-collection-handle','kalyani-cotton'), window.location.href='collection.html')">Kalyani Cotton</a>
        <a href="#" class="lm-nav-link" onclick="event.preventDefault(); (sessionStorage.setItem('lm-collection-handle','mul-cotton'), window.location.href='collection.html')">Mul Cotton</a>
        <a href="#" class="lm-nav-link" onclick="event.preventDefault(); (sessionStorage.setItem('lm-collection-handle','kadhi-cotton'), window.location.href='collection.html')">Khadi Cotton</a>
        <a href="#" class="lm-nav-link" onclick="event.preventDefault(); (sessionStorage.setItem('lm-collection-handle','banarasi'), window.location.href='collection.html')">Banarasi</a>
    </nav>
    <button id="hamburger-btn" class="lm-hamburger" aria-label="Menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    <div class="lm-nav-actions">
        <button id="search-btn" class="lm-nav-btn-icon" aria-label="Search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </button>
        <button id="account-btn" class="lm-nav-btn-icon" aria-label="My Account">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </button>
        <button id="wishlist-btn" class="lm-nav-btn-icon" aria-label="Wishlist" onclick="toggleWishlistDrawer()">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            <span class="wishlist-count" style="display:none; position:absolute; top:4px; right:2px; background:#c9943a; color:#fff; border-radius:50%; width:16px; height:16px; font-size:9px; font-weight:700; line-height:16px; text-align:center;">0</span>
        </button>
        <button id="cart-btn" class="lm-nav-btn-icon" aria-label="Cart">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            <span class="cart-count">0</span>
        </button>
    </div>
</header>
<!-- ══ MOBILE NAV ═══════════════════════════════════════════════════════════ -->
<div id="mobile-nav" class="lm-mobile-nav">
    <div class="lm-mobile-nav-eyebrow">Collections</div>
    <a href="#" class="lm-mobile-nav-link" onclick="event.preventDefault(); (sessionStorage.setItem('lm-collection-handle','kalyani-cotton'), window.location.href='collection.html')">Kalyani Cotton</a>
    <a href="#" class="lm-mobile-nav-link" onclick="event.preventDefault(); (sessionStorage.setItem('lm-collection-handle','mul-cotton'), window.location.href='collection.html')">Mul Cotton</a>
    <a href="#" class="lm-mobile-nav-link" onclick="event.preventDefault(); (sessionStorage.setItem('lm-collection-handle','kadhi-cotton'), window.location.href='collection.html')">Khadi Cotton</a>
    <a href="#" class="lm-mobile-nav-link" onclick="event.preventDefault(); (sessionStorage.setItem('lm-collection-handle','banarasi'), window.location.href='collection.html')">Banarasi</a>
    <a href="all-collections.html" class="lm-mobile-nav-link">All Collections</a>
    <div class="lm-mobile-nav-footer">
        <a href="index.html">Home</a>
        <a href="all-collections.html">Shop</a>
        <a href="#">About</a>
        <a href="#">Contact</a>
    </div>
</div>

<!-- ══ HERO ══════════════════════════════════════════════════════════════════ -->
<section class="adrini-hero">
  <div class="hero-overlay"></div>

  <div class="hero-content">
    <span class="hero-tag">
      Handpicked Across India
    </span>

    <h1>
      She who stands tall
      <span>like a mountain</span>
    </h1>

    <p>
      From India's finest weaving traditions —
      delivered to your door.
    </p>

    <a href="all-collections.html" class="hero-btn">
      Explore Collection
    </a>
  </div>
</section>

<!-- ══ TRUST BAR ═════════════════════════════════════════════════════════════ -->
<div class="lm-trust-bar">
    <div class="lm-trust-item"><span class="lm-trust-dot"></span>Free shipping on all prepaid orders</div>
    <div class="lm-trust-item"><span class="lm-trust-dot"></span>7-day returns</div>
    <div class="lm-trust-item"><span class="lm-trust-dot"></span>Curated with care</div>
    <div class="lm-trust-item"><span class="lm-trust-dot"></span>WhatsApp support</div>
    <div class="lm-trust-item"><span class="lm-trust-dot"></span>COD available</div>
    <div class="lm-trust-item"><span class="lm-trust-dot"></span>Secure checkout</div>
</div>


<!-- ══ NEW ARRIVALS ═══════════════════════════════════════════════════════════ -->
<shopify-store store-domain="adrini-5666.myshopify.com" public-access-token="5a869208a525680f7f1f91e2d8b20a97" country="IN" language="en">
<section id="new-arrivals" class="lm-products-sec" style="padding-bottom: 0;">
    <div class="lm-products-header">
        <div>
            <div class="lm-products-eyebrow">Fresh in</div>
            <h2 class="lm-products-title">New Arrivals</h2>
        </div>
        <a href="#" class="lm-products-link" onclick="event.preventDefault(); sessionStorage.setItem('lm-collection-handle','new-arrivals'); window.location.href='collection.html'">View all →</a>
    </div>
    <div class="lm-products-grid">
        <shopify-context type="collection" handle="new-arrivals">
            <template>
                <shopify-list-context type="product" query="collection.products" first="8">
                    <template>
                        <a class="lm-product-card-link" shopify-attr--href="'product.html?handle=' + product.handle">
                        <div class="lm-product-card" shopify-attr--data-id="product.id">
                            <div class="lm-product-img" style="position:relative;">
                                <button class="card-wish-btn" shopify-attr--data-id="product.selectedOrFirstAvailableVariant.id" shopify-attr--data-title="product.title" shopify-attr--data-price="product.selectedOrFirstAvailableVariant.price.amount" shopify-attr--data-img="product.selectedOrFirstAvailableVariant.image.url" shopify-attr--data-handle="product.handle" onclick="event.preventDefault(); event.stopPropagation(); window.toggleCardWishlist(this)" aria-label="Add to wishlist" style="position:absolute; top:8px; right:8px; z-index:10; background:rgba(255,255,255,0.9); border:none; border-radius:50%; width:28px; height:28px; display:flex; align-items:center; justify-content:center; cursor:pointer; color:#1a1208; box-shadow:0 2px 6px rgba(0,0,0,0.1); transition: transform 0.2s, background 0.2s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-wish-icon"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                                </button>
                                <shopify-media query="product.selectedOrFirstAvailableVariant.image" layout="fullWidth" aspect-ratio="0.75"></shopify-media>
                            </div>
                            <div class="lm-product-info">
                                <div class="lm-product-name"><shopify-data query="product.title"></shopify-data></div>
                                <div class="lm-product-bottom">
                                    <div>
                                        <span class="lm-product-price"><shopify-money format="money" query="product.selectedOrFirstAvailableVariant.price"></shopify-money></span>
                                    </div>
                                    <button class="lm-product-cart" shopify-attr--data-id="product.selectedOrFirstAvailableVariant.id" shopify-attr--data-title="product.title" shopify-attr--data-price="product.selectedOrFirstAvailableVariant.price.amount" shopify-attr--data-img="product.selectedOrFirstAvailableVariant.image.url" shopify-attr--data-handle="product.handle" shopify-attr--data-inventory="product.selectedOrFirstAvailableVariant.quantityAvailable" onclick="event.preventDefault(); event.stopPropagation(); window.addTemplateToCart(this)">Add &#8594;</button>
                                </div>
                            </div>
                        </div>
                        </a>
                    </template>
                </shopify-list-context>
            </template>
        </shopify-context>
    </div>
    
    <div class="lm-view-all-wrapper">
        <a href="#" class="lm-view-all-btn" onmouseover="this.style.background='#1a1208'; this.style.color='#c9943a'" onmouseout="this.style.background='transparent'; this.style.color='#1a1208'" onclick="event.preventDefault(); sessionStorage.setItem('lm-collection-handle','new-arrivals'); window.location.href='collection.html'">
            View all new arrivals
        </a>
    </div>
</section>

<!-- ══ COLLECTIONS ════════════════════════════════════════════════════════════ -->
<section id="collections" class="collection-section">
  <div class="image-wrapper">
    <div class="sp-imgs">
      <div class="sp-slide active" style="background-image:url('images/kalyani_cotton_v3.jpg')"></div>
      <div class="sp-slide" style="background-image:url('images/mul_cotton.jpg')"></div>
      <div class="sp-slide" style="background-image:url('images/khadi_cotton.jpg')"></div>
      <div class="sp-slide" style="background-image:url('images/banarasi_silk.jpg')"></div>
    </div>
    <div class="image-overlay"></div>
  </div>

  <div class="content-side">
    <div class="mini-title">Our Collections</div>
    <h1 class="heading">
      Woven with<br>
      <span>intention.</span>
    </h1>
    <p class="description">
      Rooted in South Indian heritage and reimagined for the modern wardrobe, every Adrini saree carries softness, craftsmanship, and timeless elegance woven into every thread.
    </p>

    <div class="collections-list">
      <div class="collection-item active" onclick="openSp(0)">
        <div class="collection-top">
          <div class="left-group">
            <div class="number">01</div>
            <div class="collection-name">Kalyani Cotton</div>
          </div>
          <div class="plus">+</div>
        </div>
        <div class="expand-content">
          <img class="collection-preview" src="images/kalyani_cotton_v3.jpg" alt="Kalyani Cotton">
          <div class="meta">Pure cotton · Temple border · Handloom finish</div>
          <p>Inspired by traditional Kerala textures with lightweight comfort and elegant woven detailing for everyday luxury.</p>
          <div class="bottom-row">
            <div class="price">From ₹899</div>
            <button class="shop-btn" onclick="event.stopPropagation(); (sessionStorage.setItem('lm-collection-handle','kalyani-cotton'), window.location.href='collection.html')">Shop Collection →</button>
          </div>
        </div>
      </div>

      <div class="collection-item" onclick="openSp(1)">
        <div class="collection-top">
          <div class="left-group">
            <div class="number">02</div>
            <div class="collection-name">Mul Cotton</div>
          </div>
          <div class="plus">+</div>
        </div>
        <div class="expand-content">
          <img class="collection-preview" src="images/mul_cotton.jpg" alt="Mul Cotton">
          <div class="meta">Breathable · Soft drape · Everyday elegance</div>
          <p>Feather-light mul cotton sarees designed for graceful movement, minimal styling, and all-day comfort.</p>
          <div class="bottom-row">
            <div class="price">From ₹1199</div>
            <button class="shop-btn" onclick="event.stopPropagation(); (sessionStorage.setItem('lm-collection-handle','mul-cotton'), window.location.href='collection.html')">Shop Collection →</button>
          </div>
        </div>
      </div>

      <div class="collection-item" onclick="openSp(2)">
        <div class="collection-top">
          <div class="left-group">
            <div class="number">03</div>
            <div class="collection-name">Khadi Cotton</div>
          </div>
          <div class="plus">+</div>
        </div>
        <div class="expand-content">
          <img class="collection-preview" src="images/khadi_cotton.jpg" alt="Khadi Cotton">
          <div class="meta">Handspun · Textured weave · Artisanal touch</div>
          <p>Rich textures and heritage-inspired patterns crafted for understated sophistication and timeless beauty.</p>
          <div class="bottom-row">
            <div class="price">From ₹1499</div>
            <button class="shop-btn" onclick="event.stopPropagation(); (sessionStorage.setItem('lm-collection-handle','kadhi-cotton'), window.location.href='collection.html')">Shop Collection →</button>
          </div>
        </div>
      </div>

      <div class="collection-item" onclick="openSp(3)">
        <div class="collection-top">
          <div class="left-group">
            <div class="number">04</div>
            <div class="collection-name">Banarasi</div>
          </div>
          <div class="plus">+</div>
        </div>
        <div class="expand-content">
          <img class="collection-preview" src="images/banarasi_silk.jpg" alt="Banarasi">
          <div class="meta">Zari work · Festive luxury · Rich motifs</div>
          <p>Elegant Banarasi drapes infused with regal borders and detailed craftsmanship for special celebrations.</p>
          <div class="bottom-row">
            <div class="price">From ₹2499</div>
            <button class="shop-btn" onclick="event.stopPropagation(); (sessionStorage.setItem('lm-collection-handle','banarasi'), window.location.href='collection.html')">Shop Collection →</button>
          </div>
        </div>
      </div>
    </div>

    <a href="all-collections.html" class="explore-btn">
      Explore All Collections →
    </a>
  </div>
</section>


<!-- ══ BEST SELLING ═══════════════════════════════════════════════════════════ -->
